---
const nav = [
  {
    href: "/portfolio/",
    label: "Portfolio",
    isActive: (path: string) => path.startsWith("/portfolio/"),
  },
  { href: "/search/", label: "Search", isActive: (path: string) => path.startsWith("/search/") },
];

const currentPath = Astro.url.pathname;
---

<a class="skip-link" href="#content">Skip to content</a>
<header class="site-header">
  <a class="brand" href="/" aria-label="ARKAI Studio home">
    <img
      class="brand-mark"
      src="/assets/brand/arkai-logo.png"
      alt=""
      width="1200"
      height="752"
    />
    <img
      class="brand-wordmark"
      src="/assets/brand/arkai-wordmark-white.png"
      alt=""
      width="2400"
      height="213"
    />
  </a>
  <nav aria-label="Primary navigation">
    {
      nav.map((item) => (
        <a href={item.href} aria-current={item.isActive(currentPath) ? "page" : undefined}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
