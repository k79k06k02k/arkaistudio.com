---
import ResponsiveImage from "./ResponsiveImage.astro";
import type { Project } from "../utils/content";
import { projectPath } from "../utils/content";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const href = projectPath(project.data.legacySlug);
const projectTypes = project.data.projectTypes;
const filterTypes = projectTypes.map((type) => type.toLowerCase()).join("|");
---

<article class="project-card" data-project-card data-project-types={filterTypes}>
  <a class="project-image" href={href}>
    {
      project.data.featuredImage ? (
        <ResponsiveImage
          src={project.data.featuredImage}
          alt=""
          loading="lazy"
          sizes="(min-width: 920px) 30vw, (min-width: 620px) 45vw, calc(100vw - 40px)"
        />
      ) : (
        <span>{project.data.title}</span>
      )
    }
  </a>
  <div class="project-body">
    <p class="card-kicker">{projectTypes.join(" / ")}</p>
    <h2><a href={href}>{project.data.title}</a></h2>
    <p>{project.data.summary}</p>
  </div>
</article>
