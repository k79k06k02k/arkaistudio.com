---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ANALYTICS, SITE } from "../config";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  pagefindBody?: boolean;
}

const defaultOgImage = "/assets/og/arkai-studio-og.webp";

const {
  title = SITE.title,
  description = SITE.description,
  canonicalPath = Astro.url.pathname,
  image = defaultOgImage,
  pagefindBody = true,
} = Astro.props;

const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
const canonical = new URL(canonicalPath, SITE.url);
const ogImage = new URL(image, SITE.url);
const usesDefaultOgImage = image === defaultOgImage;
const cloudflareAnalyticsToken = import.meta.env.PROD
  ? import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN ||
    ANALYTICS.cloudflareWebAnalyticsToken
  : undefined;
const cloudflareAnalyticsConfig = cloudflareAnalyticsToken
  ? JSON.stringify({ token: cloudflareAnalyticsToken })
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon-32x32.avif" type="image/avif" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.avif" type="image/avif" sizes="16x16" />
    <link rel="icon" href="/favicon-32x32.webp" type="image/webp" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.webp" type="image/webp" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.webp" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {usesDefaultOgImage && <meta property="og:image:type" content="image/webp" />}
    {usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {usesDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <Header />
    <main id="content" data-pagefind-body={pagefindBody ? "" : undefined}>
      <slot />
    </main>
    <Footer />
    {
      cloudflareAnalyticsConfig && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={cloudflareAnalyticsConfig}
        />
      )
    }
  </body>
</html>
