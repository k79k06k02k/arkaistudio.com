---
import { getCollection } from "astro:content";
import RedirectPage from "../../../../components/RedirectPage.astro";
import { projectPath } from "../../../../utils/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.data.legacySlug },
    props: { target: projectPath(project.data.legacySlug) },
  }));
}

const { target } = Astro.props;
---

<RedirectPage to={target} title="Redirecting to portfolio" />
