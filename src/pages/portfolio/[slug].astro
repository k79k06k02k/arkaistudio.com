---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectMediaCarousel from "../../components/ProjectMediaCarousel.astro";
import ResponsiveImage from "../../components/ResponsiveImage.astro";
import { formatDate, projectPath } from "../../utils/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.data.legacySlug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const mediaImages = [project.data.featuredImage, ...project.data.gallery].filter(
  (image): image is string => Boolean(image),
);
const hasRichMedia = project.data.gallery.length > 0 || project.data.videos.length > 0;
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  canonicalPath={projectPath(project.data.legacySlug)}
  image={project.data.featuredImage}
>
  <article class="article-shell project-detail">
    <header class="article-header">
      <p class="eyebrow">{project.data.projectTypes.join(" / ")}</p>
      <h1>{project.data.title}</h1>
      <p class="article-meta">
        Portfolio date <time datetime={project.data.date.toISOString()}>{formatDate(project.data.date)}</time>
      </p>
    </header>
    {
      hasRichMedia ? (
        <ProjectMediaCarousel title={project.data.title} images={mediaImages} videos={project.data.videos} />
      ) : (
        project.data.featuredImage && (
          <ResponsiveImage
            class="article-hero-image"
            src={project.data.featuredImage}
            alt=""
            loading="eager"
            sizes="(min-width: 860px) 760px, calc(100vw - 40px)"
            fetchpriority="high"
          />
        )
      )
    }
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
